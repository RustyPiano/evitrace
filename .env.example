APP_NAME=EviTrace
ENV=development
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_HOURS=8
DATABASE_URL=sqlite:///./data/app.db
DATA_ROOT=./data
MAX_UPLOAD_MB=200
CORS_ORIGINS=http://localhost:5173
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
LOCAL_LLM_API_KEY=local
LOCAL_LLM_MODEL=qwen-local
LLM_TIMEOUT_SEC=180
LLM_MAX_RETRIES=2
MOCK_AI=true
# Optional split overrides. Leave empty to follow MOCK_AI.
MOCK_LLM=
MOCK_MEDIA=
# Cloud OpenAI-compatible LLM with mock OCR/ASR/video example:
# MOCK_AI=false
# MOCK_LLM=false
# MOCK_MEDIA=true
# LOCAL_LLM_BASE_URL=https://api.deepseek.com/v1
# LOCAL_LLM_API_KEY=<put-your-key-in-private-.env-only>
# LOCAL_LLM_MODEL=deepseek-chat
OCR_MODEL_DIR=
ASR_MODEL_DIR=
ASR_MODEL_SIZE=small
FFMPEG_TIMEOUT_SEC=120
VIDEO_FRAME_INTERVAL_SEC=10
TIME_CONFLICT_MINUTES=30
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123456
